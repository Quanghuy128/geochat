{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/careful.sh\"",
            "statusMessage": "careful: kiểm tra lệnh phá hủy"
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/freeze.sh\"",
            "statusMessage": "freeze: kiểm tra vùng đóng băng"
          }
        ]
      }
    ]
  }
}
