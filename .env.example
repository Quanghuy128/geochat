# Copy sang .env.local rồi điền giá trị thật. KHÔNG commit .env.local.

# Supabase — lấy từ Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Google Maps JS API key — Google Cloud Console > APIs & Services > Credentials
# Bật: Maps JavaScript API
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
